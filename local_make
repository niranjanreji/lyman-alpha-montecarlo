# Monte Carlo Lyman-alpha RT integration

CXX = mpicxx
CXXFLAGS = -std=c++20 -O3 -fopenmp -DPARALLEL -c
LDFLAGS += -fopenmp -lstdc++
INCLUDE_DIRS += -I./src -I.
VPATH += :./src

OBJ += pluto_interface.o mc_grid.o photons.o monte_carlo.o physics.o voigt.o user_setup.o

.cpp.o:
	$(CXX) $(CXXFLAGS) $(INCLUDE_DIRS) $<
